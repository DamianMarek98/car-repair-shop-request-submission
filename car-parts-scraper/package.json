{
  "name": "car-parts-scraper",
  "version": "1.0.0",
  "description": "Playwright-based scraper for car parts aggregation from external websites",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && npm run copy-static",
    "copy-static": "cp -r src/public dist/",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "scrape": "tsx src/scraper.ts",
    "parse-interparts": "tsx src/inter-parts/interPartsParser.ts",
    "parse-apcat": "tsx src/apcat/apcatParser.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.2",
    "playwright": "^1.50.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "~5.4.0"
  }
}
